# Azure AI Foundry (OpenAI-compatible)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_MODEL=gpt-5.3-chat

# Optional: LangSmith for tracing
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=deepagent-generator

# Infrastructure (docker-compose.infra.yml)
TASKMANAGER_DB_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
GRAFANA_ADMIN_PASSWORD=change-me
FLAGSMITH_DB_PASSWORD=change-me
VAULT_TOKEN=change-me
